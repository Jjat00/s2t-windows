# ── Sensitive / secrets ───────────────────────────────────────────────────
.env

# ── Python ────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/

# ── Virtual environment ───────────────────────────────────────────────────
.venv/
venv/
env/

# ── IDE / editor ──────────────────────────────────────────────────────────
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# ── OS ────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── PyInstaller build output ──────────────────────────────────────────────
*.spec
*.exe
*.manifest

# ── Logs ──────────────────────────────────────────────────────────────────
*.log
logs/

# ── Model cache (faster-whisper / huggingface) ────────────────────────────
