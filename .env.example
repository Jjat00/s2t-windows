# STT Engine: "auto" (recommended), "deepgram", or "whisper"
# auto = Deepgram if DEEPGRAM_API_KEY is set, otherwise Whisper (local, no API key needed)
ENGINE=auto

# Deepgram API key — optional, only needed if ENGINE=deepgram or ENGINE=auto with a key
# Get a free key at https://console.deepgram.com
DEEPGRAM_API_KEY=

# Whisper model size: tiny, base, small, medium, large-v3
# Larger = more accurate but slower and more memory
WHISPER_MODEL=small

# Whisper compute type: int8 (CPU), float16 (GPU), float32
WHISPER_COMPUTE_TYPE=int8

# Audio device index (leave blank for default mic)
AUDIO_DEVICE_INDEX=

# Pause/silence threshold in milliseconds before ending an utterance
# 300 = faster response, may cut off trailing words
# 500 = more natural, recommended for dictation
ENDPOINTING_MS=500

# Show partial results while you speak (true) or wait for final only (false)
# true = texto aparece en tiempo real, puede parpadear levemente al corregirse
# false = texto aparece solo al terminar la frase, más estable
INTERIM_RESULTS=true

# Language for transcription
# multi  = Spanish + English simultaneously (recommended — Deepgram nova-3)
# es     = Spanish only
# en-US  = English only
# auto   = same as multi (Deepgram) or auto-detect (Whisper)
# Other BCP-47 tags: fr, pt, de, it, ja, zh
LANGUAGE=multi

# Global hotkey to toggle recording on/off (uses pynput key names)
TOGGLE_HOTKEY=<f9>
