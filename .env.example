# STT Engine selection: "deepgram" or "whisper"
ENGINE=deepgram

# Deepgram API key (get from https://console.deepgram.com)
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# Whisper model size: tiny, base, small, medium, large-v3
# Larger = more accurate but slower and more memory
WHISPER_MODEL=small

# Whisper compute type: int8 (CPU), float16 (GPU), float32
WHISPER_COMPUTE_TYPE=int8

# Audio device index (leave blank for default mic)
AUDIO_DEVICE_INDEX=

# Pause/silence threshold in milliseconds before ending an utterance
ENDPOINTING_MS=300

# Show partial results while you speak (true) or wait for final only (false)
# true = texto aparece en tiempo real, puede parpadear levemente al corregirse
# false = texto aparece solo al terminar la frase, más estable
INTERIM_RESULTS=true

# Language for transcription (BCP-47 tag or "auto")
# Examples: es, es-419, en-US, fr, pt, de, it, ja, zh
LANGUAGE=es

# Global hotkey to toggle recording on/off (uses pynput key names)
TOGGLE_HOTKEY=<f9>
